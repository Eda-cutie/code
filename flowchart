import React, { useState, useEffect } from 'react';
import { 
  UserPlus, 
  LogIn, 
  FileText, 
  Activity, 
  Shield, 
  Clock, 
  ChevronRight, 
  ChevronDown, 
  ChevronLeft,
  Sparkles,
  Loader2,
  AlertCircle
} from 'lucide-react';

// Data configuration for the modules
const modules = {
  reg: {
    title: "User Registration",
    icon: UserPlus,
    desc: "Users create an account by providing personal details such as name, email, and password. The system validates and stores this information securely in the database.",
    color: "text-blue-500 dark:text-blue-400",
    bg: "bg-blue-500/10 dark:bg-blue-400/10",
    border: "border-blue-500/50 dark:border-blue-400/50",
    ring: "ring-blue-500/30",
    aiPrompt: "Suggest 3 security best practices and 2 user experience improvements for a User Registration module in a complaint management system."
  },
  login: {
    title: "User Login",
    icon: LogIn,
    desc: "Registered users log in using their username and password to access the complaint dashboard.",
    color: "text-indigo-500 dark:text-indigo-400",
    bg: "bg-indigo-500/10 dark:bg-indigo-400/10",
    border: "border-indigo-500/50 dark:border-indigo-400/50",
    ring: "ring-indigo-500/30",
    aiPrompt: "What are the modern authentication standards (like MFA or SSO) that should be integrated into a professional login system?"
  },
  sub: {
    title: "Complaint Submission",
    icon: FileText,
    desc: "Users can submit complaints through an online form by selecting category, subcategory, and providing a description of the issue.",
    color: "text-purple-500 dark:text-purple-400",
    bg: "bg-purple-500/10 dark:bg-purple-400/10",
    border: "border-purple-500/50 dark:border-purple-400/50",
    ring: "ring-purple-500/30",
    aiPrompt: "Suggest a list of effective complaint categories and subcategories for a general service-based organization."
  },
  admin: {
    title: "Admin Management",
    icon: Shield,
    desc: "The administrator can log into the admin panel to view all complaints, manage categories, and update the complaint status.",
    color: "text-red-500 dark:text-red-400",
    bg: "bg-red-500/10 dark:bg-red-400/10",
    border: "border-red-500/50 dark:border-red-400/50",
    ring: "ring-red-500/30",
    aiPrompt: "Propose a dashboard layout for an administrator handling thousands of complaints. What KPIs should be displayed?"
  },
  track: {
    title: "Complaint Tracking",
    icon: Activity,
    desc: "Users can view and track the status of their submitted complaints through their dashboard.",
    color: "text-amber-500 dark:text-amber-400",
    bg: "bg-amber-500/10 dark:bg-amber-400/10",
    border: "border-amber-500/50 dark:border-amber-400/50",
    ring: "ring-amber-500/30",
    aiPrompt: "How can we provide 'delightful' status updates to users during a long complaint resolution process to reduce anxiety?"
  },
  hist: {
    title: "Complaint History",
    icon: Clock,
    desc: "The system maintains a record of all previously submitted complaints for reference and monitoring.",
    color: "text-teal-500 dark:text-teal-400",
    bg: "bg-teal-500/10 dark:bg-teal-400/10",
    border: "border-teal-500/50 dark:border-teal-400/50",
    ring: "ring-teal-500/30",
    aiPrompt: "What data visualization techniques are best for showing complaint trends over a 12-month period?"
  }
};

export default function App() {
  const [activeId, setActiveId] = useState('reg');
  const [aiAnalysis, setAiAnalysis] = useState({});
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  const apiKey = ""; // API key is handled by the environment

  const handleNodeClick = (id) => {
    setActiveId(id);
    setError(null);
  };

  const generateAiInsights = async (id) => {
    setLoading(true);
    setError(null);
    const prompt = modules[id].aiPrompt;
    
    const fetchWithRetry = async (retries = 0) => {
      try {
        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: prompt }] }],
              systemInstruction: { 
                parts: [{ text: "You are a software architect expert. Provide concise, professional, and actionable advice in bullet points. Keep it under 150 words." }] 
              }
            })
          }
        );

        if (!response.ok) throw new Error('Failed to fetch from Gemini');
        
        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
        
        setAiAnalysis(prev => ({ ...prev, [id]: text }));
      } catch (err) {
        if (retries < 5) {
          const delay = Math.pow(2, retries) * 1000;
          await new Promise(resolve => setTimeout(resolve, delay));
          return fetchWithRetry(retries + 1);
        }
        setError("Could not generate AI insights. Please try again later.");
      } finally {
        setLoading(false);
      }
    };

    await fetchWithRetry();
  };

  // Node Component
  const FlowNode = ({ id }) => {
    const module = modules[id];
    const Icon = module.icon;
    const isActive = activeId === id;

    return (
      <button
        onClick={() => handleNodeClick(id)}
        className={`group flex flex-col items-center justify-center p-4 w-44 sm:w-48 rounded-2xl border-2 transition-all duration-300 relative overflow-hidden backdrop-blur-sm ${
          isActive
            ? `${module.border} bg-white/90 dark:bg-gray-900/90 shadow-xl scale-105 ring-4 ${module.ring}`
            : 'border-gray-200/60 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 bg-white/60 dark:bg-gray-800/60 hover:shadow-md'
        }`}
      >
        <div className={`p-3 rounded-full mb-3 transition-colors duration-300 ${isActive ? module.bg : 'bg-gray-100 dark:bg-gray-800 group-hover:bg-gray-200 dark:group-hover:bg-gray-700'}`}>
          <Icon className={`w-6 h-6 transition-colors duration-300 ${isActive ? module.color : 'text-gray-500 dark:text-gray-400 group-hover:text-gray-700 dark:group-hover:text-gray-300'}`} />
        </div>
        <h3 className={`font-bold text-sm text-center leading-tight transition-colors duration-300 ${isActive ? 'text-gray-900 dark:text-white' : 'text-gray-600 dark:text-gray-300 group-hover:text-gray-800 dark:group-hover:text-gray-200'}`}>
          {module.title}
        </h3>
      </button>
    );
  };

  const ArrowRight = () => (
    <div className="flex items-center w-full px-1">
      <div className="h-0.5 flex-1 bg-gradient-to-r from-gray-300 to-gray-500 dark:from-gray-600 dark:to-gray-400" />
      <ChevronRight className="w-6 h-6 text-gray-500 dark:text-gray-400 -ml-2 shrink-0" />
    </div>
  );

  const ArrowDown = () => (
    <div className="flex flex-col items-center h-12 py-1">
      <div className="w-0.5 flex-1 bg-gradient-to-b from-gray-300 to-gray-500 dark:from-gray-600 dark:to-gray-400" />
      <ChevronDown className="w-6 h-6 text-gray-500 dark:text-gray-400 -mt-2 shrink-0" />
    </div>
  );

  const ArrowLeft = () => (
    <div className="flex items-center w-full px-1">
      <ChevronLeft className="w-6 h-6 text-gray-500 dark:text-gray-400 -mr-2 shrink-0 z-10" />
      <div className="h-0.5 flex-1 bg-gradient-to-l from-gray-300 to-gray-500 dark:from-gray-600 dark:to-gray-400" />
    </div>
  );

  return (
    <div className="w-full min-h-screen p-4 sm:p-8 font-sans text-gray-900 dark:text-gray-100">
      
      <div className="text-center mb-12">
        <h1 className="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">
          Complaint Management <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-teal-400">System Flow</span>
        </h1>
        <p className="text-gray-500 dark:text-gray-400 font-medium italic">Interactive Architecture Powered by AI</p>
      </div>

      <div className="max-w-5xl mx-auto w-full">
        
        {/* MOBILE VIEW */}
        <div className="md:hidden flex flex-col items-center w-full pb-10">
          <FlowNode id="reg" />
          <ArrowDown />
          <FlowNode id="login" />
          <ArrowDown />
          <FlowNode id="sub" />
          <ArrowDown />
          <FlowNode id="track" />
          <ArrowDown />
          <FlowNode id="hist" />
          <div className="flex w-full justify-center items-center py-6 gap-4 px-8">
            <div className="h-[1px] flex-1 bg-gray-300 dark:bg-gray-700"></div>
            <span className="text-xs font-semibold text-gray-400 uppercase tracking-widest">Admin Flow</span>
            <div className="h-[1px] flex-1 bg-gray-300 dark:bg-gray-700"></div>
          </div>
          <FlowNode id="admin" />
        </div>

        {/* DESKTOP VIEW */}
        <div className="hidden md:grid grid-cols-[1fr_80px_auto_80px_1fr] lg:grid-cols-[1fr_120px_auto_120px_1fr] gap-y-2 items-center w-full max-w-4xl mx-auto relative z-10">
          <div className="col-start-1 flex justify-end"><FlowNode id="reg" /></div>
          <div className="col-start-2 flex justify-center w-full"><ArrowRight /></div>
          <div className="col-start-3 flex justify-center"><FlowNode id="login" /></div>
          <div className="col-start-3 flex justify-center"><ArrowDown /></div>
          <div className="col-start-3 flex justify-center"><FlowNode id="sub" /></div>
          <div className="col-start-3 flex justify-center"><ArrowDown /></div>
          <div className="col-start-3 flex justify-center"><FlowNode id="track" /></div>
          <div className="col-start-4 flex justify-center w-full"><ArrowLeft /></div>
          <div className="col-start-5 flex justify-start"><FlowNode id="admin" /></div>
          <div className="col-start-3 flex justify-center"><ArrowDown /></div>
          <div className="col-start-3 flex justify-center"><FlowNode id="hist" /></div>
        </div>

        {/* DETAILS & AI PANEL */}
        <div className="mt-16 w-full max-w-4xl mx-auto space-y-6">
          <div className="relative rounded-2xl border border-gray-200/50 dark:border-gray-700/50 bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl shadow-2xl overflow-hidden transition-all duration-500">
            <div className={`absolute -inset-24 opacity-20 blur-3xl transition-colors duration-500 rounded-full pointer-events-none ${modules[activeId].bg}`} />

            <div className="relative p-6 sm:p-8 flex flex-col gap-6">
              <div className="flex flex-col sm:flex-row gap-6 items-start">
                <div className={`p-5 rounded-2xl shrink-0 ${modules[activeId].bg} border ${modules[activeId].border} shadow-inner`}>
                  {React.createElement(modules[activeId].icon, { className: `w-10 h-10 ${modules[activeId].color}` })}
                </div>
                
                <div className="flex-1">
                  <div className="flex flex-wrap items-center gap-3 mb-2">
                    <h2 className="text-2xl font-bold text-gray-900 dark:text-white">
                      {modules[activeId].title}
                    </h2>
                    <span className={`text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider ${modules[activeId].bg} ${modules[activeId].color}`}>
                      Core Module
                    </span>
                  </div>
                  <p className="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
                    {modules[activeId].desc}
                  </p>
                </div>
              </div>

              {/* AI Interaction Section */}
              <div className="mt-4 pt-6 border-t border-gray-100 dark:border-gray-800">
                <div className="flex items-center justify-between mb-4">
                  <div className="flex items-center gap-2 text-sm font-semibold text-gray-500 uppercase tracking-wider">
                    <Sparkles className="w-4 h-4 text-amber-500" />
                    <span>Architect Insights</span>
                  </div>
                  
                  {!aiAnalysis[activeId] && (
                    <button
                      onClick={() => generateAiInsights(activeId)}
                      disabled={loading}
                      className="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-lg text-sm font-medium transition-all shadow-lg shadow-blue-500/20 disabled:opacity-50"
                    >
                      {loading ? <Loader2 className="w-4 h-4 animate-spin" /> : <Sparkles className="w-4 h-4" />}
                      Generate ✨ AI Strategy
                    </button>
                  )}
                </div>

                {error && (
                  <div className="flex items-center gap-2 p-3 text-sm text-red-600 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-800">
                    <AlertCircle className="w-4 h-4" />
                    {error}
                  </div>
                )}

                {aiAnalysis[activeId] && (
                  <div className="p-5 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-100 dark:border-gray-700 animate-in fade-in slide-in-from-bottom-2">
                    <div className="prose prose-sm dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 whitespace-pre-line">
                      {aiAnalysis[activeId]}
                    </div>
                    <button 
                      onClick={() => generateAiInsights(activeId)}
                      className="mt-4 text-xs font-medium text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1"
                    >
                      <Sparkles className="w-3 h-3" /> Regenerate Analysis
                    </button>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}
